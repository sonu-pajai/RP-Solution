<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "Masters", reporting_entities_path %><span class="separator">›</span> Periods
<% end %>

<div class="page-header">
  <h2>Periods</h2>
  <div class="flex-row">
    <% if can? :create, Period %>
      <%= link_to "＋ Add New", new_period_path, class: "btn-primary btn-sm" %>
      <%= link_to "Bulk Upload", bulk_upload_periods_path, class: "btn-primary btn-sm btn-outline" %>
    <% end %>
  </div>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th>Month</th>
      <th>Financial Year</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @periods.each do |period| %>
      <tr>
        <td><%= period.month %></td>
        <td><%= period.financial_year %></td>
        <td>
          <% if can? :update, period %>
            <%= link_to "Edit", edit_period_path(period), class: "action-link" %>
          <% end %>
          <% if can? :destroy, period %>
            <%= link_to "Delete", period_path(period), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "action-link danger" %>
          <% end %>
        </td>
      </tr>
    <% end %>
    <% if @periods.empty? %>
      <tr><td colspan="3" class="empty-row">No periods yet.</td></tr>
    <% end %>
  </tbody>
</table>
