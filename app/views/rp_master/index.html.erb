<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "RP List", rp_list_path %><span class="separator">›</span> RP Master
<% end %>

<div class="page-header">
  <h2>RP Master</h2>
  <div class="flex-row">
    <%= link_to "Create", new_rp_master_path, class: "btn-primary btn-sm" %>
    <%= link_to "Bulk Upload", rp_master_bulk_upload_path, class: "btn-primary btn-sm btn-outline" %>
    <%= link_to "Export CSV", rp_master_export_path(unique_code: params[:unique_code]), class: "btn-primary btn-sm btn-outline" %>
  </div>
</div>

<div class="filter-bar">
  <div class="flex-row-end">
    <div class="form-group mb-0" style="max-width:500px;">
      <%= text_field_tag :unique_code, params[:unique_code], placeholder: "Type Unique Code..", id: "code-filter", autocomplete: "off", class: "form-control" %>
    </div>
    <a href="#" id="search-btn" class="btn-primary btn-sm">Search</a>
    <% if params[:unique_code].present? %>
      <%= link_to "Clear", rp_master_path, class: "action-link" %>
    <% end %>
  </div>
</div>
<div class="overflow-x">
  <table class="data-table">
    <thead>
      <tr>
        <th>Unique Code</th>
        <th>Salutation</th>
        <th>Name</th>
        <th>PAN</th>
        <th>Category</th>
        <th>Specific Relationship</th>
        <th>Related to Director</th>
        <th>DOB / Incorporation</th>
        <th>RP SEBI</th>
        <th>RP Companies Act</th>
        <th>RP AS-18</th>
        <th>RP IND AS-24</th>
        <th>Other Guidelines</th>
        <th>Status</th>
        <th>Created By</th>
        <th>Approved By</th>
        <th>Admin Approved By</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if @rp_masters.present? %>
        <% @rp_masters.each do |rp| %>
          <tr>
            <td><%= rp.unique_code %></td>
            <td><%= rp.salutation %></td>
            <td><%= rp.name %></td>
            <td><%= rp.pan %></td>
            <td><%= rp.category %></td>
            <td><%= rp.specific_relationship %></td>
            <td><%= rp.related_to_director %></td>
            <td><%= rp.formatted_dob %></td>
            <td><%= rp.related_party_sebi ? "Yes" : "No" %></td>
            <td><%= rp.related_party_companies_act ? "Yes" : "No" %></td>
            <td><%= rp.related_party_as18 ? "Yes" : "No" %></td>
            <td><%= rp.related_party_ind_as24 ? "Yes" : "No" %></td>
            <td><%= rp.other_guidelines %></td>
            <td><%= rp.active ? "Active" : "In-Active" %></td>
            <td><%= rp.created_by&.name %></td>
            <td><%= rp.approved_by&.name %></td>
            <td><%= rp.admin_approved_by&.name %></td>
            <td class="nowrap">
              <%= link_to "View", show_rp_master_path(rp), class: "action-link" %>
              <%= link_to "Edit", edit_rp_master_path(rp), class: "action-link" %>
              <%= link_to "Delete", destroy_rp_master_path(rp), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "action-link danger" %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="18" class="empty-row">No records found.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>


<script>
  var codeFilter = document.getElementById('code-filter');
  var searchBtn = document.getElementById('search-btn');

  function applyFilters() {
    var params = [];
    if (codeFilter.value) params.push('unique_code=' + encodeURIComponent(codeFilter.value));
    window.location.href = '/rp_master' + (params.length ? '?' + params.join('&') : '');
  }

  searchBtn.addEventListener('click', function(e) {
    e.preventDefault();
    applyFilters();
  });

  codeFilter.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      applyFilters();
    }
  });
</script>

<%= render "shared/pagination", collection: @rp_masters %>
