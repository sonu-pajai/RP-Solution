<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "RP List", rp_list_path %><span class="separator">›</span> RP Master
<% end %>

<div style="margin-bottom:8px; display:flex; justify-content:space-between; align-items:center;">
  <div>
    <h2 style="margin:0;">RP Master</h2>
    <p style="margin:4px 0 0; color:#64748b; font-size:14px;">Manage and monitor Related Party master data</p>
  </div>
  <div class="flex-row">
    <%= link_to "+ Create", new_rp_master_path, class: "btn-primary btn-sm" %>
    <%= link_to "Bulk Upload", rp_master_bulk_upload_path, class: "btn-primary btn-sm btn-outline" %>
    <%= link_to "Export CSV", rp_master_export_path(search: params[:search], category: params[:category]), class: "btn-primary btn-sm btn-outline" %>
  </div>
</div>

<!-- Stat Cards -->
<div class="rp-stat-cards">
  <div class="rp-stat-card">
    <div class="rp-stat-icon blue">👥</div>
    <div class="rp-stat-info">
      <span class="rp-stat-label">Total Related Parties</span>
      <span class="rp-stat-value"><%= @total_count %></span>
    </div>
  </div>
  <div class="rp-stat-card">
    <div class="rp-stat-icon orange">👤</div>
    <div class="rp-stat-info">
      <span class="rp-stat-label">Directors / KMP</span>
      <span class="rp-stat-value"><%= @directors_count %></span>
    </div>
  </div>
  <div class="rp-stat-card">
    <div class="rp-stat-icon green">🏢</div>
    <div class="rp-stat-info">
      <span class="rp-stat-label">Subsidiaries</span>
      <span class="rp-stat-value"><%= @subsidiaries_count %></span>
    </div>
  </div>
  <div class="rp-stat-card">
    <div class="rp-stat-icon teal">📋</div>
    <div class="rp-stat-info">
      <span class="rp-stat-label">Pending Review</span>
      <span class="rp-stat-value"><%= @pending_count %></span>
    </div>
  </div>
</div>

<!-- Search & Advanced Filters -->
<div class="rp-search-section">
  <div class="rp-search-row">
    <div class="rp-search-box">
      <span class="rp-search-icon">🔍</span>
      <%= text_field_tag :search, params[:search], placeholder: "Search by Name, PAN, DIN, CIN or RP Code...", id: "search-input", autocomplete: "off", class: "rp-search-input" %>
    </div>
    <a href="#" id="toggle-filters" class="rp-advanced-btn">🔽 Advanced Filters</a>
    <% if params[:search].present? || params[:category].present? || params[:relationship].present? || params[:sebi].present? || params[:companies_act].present? || params[:status].present? %>
      <%= link_to "↺ Clear", rp_master_path, class: "rp-clear-link" %>
    <% end %>
  </div>

  <div class="rp-filters-row" id="advanced-filters" style="<%= 'display:none;' unless params[:category].present? || params[:relationship].present? || params[:sebi].present? || params[:companies_act].present? || params[:status].present? %>">
    <div class="rp-filter-group">
      <label>Category</label>
      <%= select_tag :category, options_for_select([["All", ""]] + Relationship::CATEGORIES.map { |c| [c, c] }, params[:category]), id: "filter-category", class: "rp-filter-select" %>
    </div>
    <div class="rp-filter-group">
      <label>Relationship</label>
      <%= select_tag :relationship, options_for_select([["All", ""]] + Relationship.pluck(:name).map { |r| [r, r] }, params[:relationship]), id: "filter-relationship", class: "rp-filter-select" %>
    </div>
    <div class="rp-filter-group">
      <label>SEBI Applicability</label>
      <%= select_tag :sebi, options_for_select([["All", ""], ["Applicable", "yes"], ["Not Applicable", "no"]], params[:sebi]), id: "filter-sebi", class: "rp-filter-select" %>
    </div>
    <div class="rp-filter-group">
      <label>Companies Act</label>
      <%= select_tag :companies_act, options_for_select([["All", ""], ["Applicable", "yes"], ["Not Applicable", "no"]], params[:companies_act]), id: "filter-companies-act", class: "rp-filter-select" %>
    </div>
    <div class="rp-filter-group">
      <label>Status</label>
      <%= select_tag :status, options_for_select([["All", ""], ["Active", "active"], ["Inactive", "inactive"]], params[:status]), id: "filter-status", class: "rp-filter-select" %>
    </div>
  </div>
</div>

<!-- Category Tabs -->
<div class="rp-tabs">
  <% tab_params = request.params.except(:tab, :page) %>
  <%= link_to "All (#{@tab_counts[:all]})", rp_master_path(tab_params), class: "rp-tab #{'rp-tab-active' if @active_tab == 'all'}" %>
  <%= link_to "Directors / KMP (#{@tab_counts[:directors]})", rp_master_path(tab_params.merge(tab: 'directors')), class: "rp-tab #{'rp-tab-active' if @active_tab == 'directors'}" %>
  <%= link_to "Subsidiaries (#{@tab_counts[:subsidiaries]})", rp_master_path(tab_params.merge(tab: 'subsidiaries')), class: "rp-tab #{'rp-tab-active' if @active_tab == 'subsidiaries'}" %>
  <%= link_to "Associates (#{@tab_counts[:associates]})", rp_master_path(tab_params.merge(tab: 'associates')), class: "rp-tab #{'rp-tab-active' if @active_tab == 'associates'}" %>
  <%= link_to "Promoters (#{@tab_counts[:promoters]})", rp_master_path(tab_params.merge(tab: 'promoters')), class: "rp-tab #{'rp-tab-active' if @active_tab == 'promoters'}" %>
  <%= link_to "Others (#{@tab_counts[:others]})", rp_master_path(tab_params.merge(tab: 'others')), class: "rp-tab #{'rp-tab-active' if @active_tab == 'others'}" %>
</div>

<!-- Data Table -->
<div class="rp-table-wrapper">
  <table class="rp-table">
    <thead>
      <tr>
        <th><%= sort_link("unique_code", "RP Code") %></th>
        <th>Salutation</th>
        <th><%= sort_link("name", "Name") %></th>
        <th>PAN</th>
        <th><%= sort_link("category", "Category") %></th>
        <th><%= sort_link("specific_relationship", "Relationship") %></th>
        <th>Related to Director</th>
        <th>DOB / Incorporation</th>
        <th>SEBI</th>
        <th>Companies Act</th>
        <th>AS-18</th>
        <th>IND AS-24</th>
        <th>Other Guidelines</th>
        <th>Status</th>
        <th>Created By</th>
        <th>Approved By</th>
        <th>Admin Approved By</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if @rp_masters.present? %>
        <% @rp_masters.each do |rp| %>
          <tr>
            <td class="rp-code"><%= rp.unique_code %></td>
            <td><%= rp.salutation %></td>
            <td><%= rp.name %></td>
            <td><%= rp.pan %></td>
            <td><%= rp.category %></td>
            <td><%= rp.specific_relationship %></td>
            <td><%= rp.related_to_director %></td>
            <td><%= rp.formatted_dob %></td>
            <td><span class="<%= rp.related_party_sebi ? 'rp-bool-yes' : 'rp-bool-no' %>"><%= rp.related_party_sebi ? 'Yes' : 'No' %></span></td>
            <td><span class="<%= rp.related_party_companies_act ? 'rp-bool-yes' : 'rp-bool-no' %>"><%= rp.related_party_companies_act ? 'Yes' : 'No' %></span></td>
            <td><span class="<%= rp.related_party_as18 ? 'rp-bool-yes' : 'rp-bool-no' %>"><%= rp.related_party_as18 ? 'Yes' : 'No' %></span></td>
            <td><span class="<%= rp.related_party_ind_as24 ? 'rp-bool-yes' : 'rp-bool-no' %>"><%= rp.related_party_ind_as24 ? 'Yes' : 'No' %></span></td>
            <td><%= rp.other_guidelines %></td>
            <td><span class="<%= rp.active ? 'rp-bool-yes' : 'rp-bool-no' %>"><%= rp.active ? 'Active' : 'Inactive' %></span></td>
            <td><%= rp.created_by&.name %></td>
            <td><%= rp.approved_by&.name %></td>
            <td><%= rp.admin_approved_by&.name %></td>
            <td class="rp-actions">
              <%= link_to "👁", show_rp_master_path(rp), title: "View", class: "rp-action-icon" %>
              <%= link_to "✏️", edit_rp_master_path(rp), title: "Edit", class: "rp-action-icon" %>
              <%= link_to "🗑", destroy_rp_master_path(rp), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, title: "Delete", class: "rp-action-icon" %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="18" class="empty-row">No records found.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<div class="rp-pagination-bar">
  <span class="rp-showing-text">
    Showing <%= @rp_masters.offset_value + 1 %> to <%= [@rp_masters.offset_value + @rp_masters.limit_value, @rp_masters.total_count].min %> of <%= @rp_masters.total_count %> entries
  </span>
  <div class="rp-pagination-right">
    <select id="per-page-select" class="rp-per-page-select">
      <% [10, 25, 50, 100].each do |n| %>
        <option value="<%= n %>" <%= 'selected' if (params[:per_page] || 10).to_i == n %>><%= n %> per page</option>
      <% end %>
    </select>
    <%= render "shared/pagination", collection: @rp_masters %>
  </div>
</div>



<script>
  // Toggle advanced filters
  document.getElementById('toggle-filters').addEventListener('click', function(e) {
    e.preventDefault();
    var el = document.getElementById('advanced-filters');
    el.style.display = el.style.display === 'none' ? '' : 'none';
  });

  // Build URL with current params
  function buildUrl(extraParams) {
    var params = new URLSearchParams(window.location.search);
    Object.keys(extraParams).forEach(function(k) {
      if (extraParams[k]) params.set(k, extraParams[k]);
      else params.delete(k);
    });
    params.delete('page');
    return '/rp_master' + (params.toString() ? '?' + params.toString() : '');
  }

  // Search on Enter
  document.getElementById('search-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      window.location.href = buildUrl({ search: this.value });
    }
  });

  // Advanced filter dropdowns
  ['filter-category', 'filter-relationship', 'filter-sebi', 'filter-companies-act', 'filter-status'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el && el.tomselect) {
      el.tomselect.on('change', function(val) {
        var key = id.replace('filter-', '').replace('-', '_');
        var obj = {};
        obj[key] = val;
        window.location.href = buildUrl(obj);
      });
    } else if (el) {
      el.addEventListener('change', function() {
        var key = id.replace('filter-', '').replace('-', '_');
        var obj = {};
        obj[key] = this.value;
        window.location.href = buildUrl(obj);
      });
    }
  });

  // Per page
  var perPageEl = document.getElementById('per-page-select');
  if (perPageEl && perPageEl.tomselect) {
    perPageEl.tomselect.on('change', function(val) {
      window.location.href = buildUrl({ per_page: val });
    });
  } else if (perPageEl) {
    perPageEl.addEventListener('change', function() {
      window.location.href = buildUrl({ per_page: this.value });
    });
  }
</script>
