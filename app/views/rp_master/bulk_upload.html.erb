<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "RP Master", rp_master_path %> <span class="separator">›</span> Bulk Upload
<% end %>

<h2>Bulk Upload RP Master</h2>

<div style="background:#fff; padding:24px; border-radius:10px; border:1px solid #e2e8f0;">
  <%= form_with(url: rp_master_bulk_upload_path, method: :post, multipart: true) do |f| %>
    <div class="form-group">
      <%= f.label :file, "Upload CSV File" %>
      <%= f.file_field :file, accept: ".csv" %>
    </div>

    <p style="font-size:13px; color:#64748b; margin-top:8px;">
      CSV columns: Reporting Entity, Salutation, Name, PAN, Category, Specific Relationship, DOB/Incorporation Date, Related to Director (Yes/No), RP as per SEBI (Yes/No), RP as per Companies Act (Yes/No), RP as per AS-18 (Yes/No), RP as per IND AS-24 (Yes/No), Other Guidelines, Active (Yes/No)
    </p>

    <div class="form-actions" style="margin-top:16px;">
      <%= f.submit "Upload", class: "btn-primary btn-submit" %>
      <%= link_to "Download Template", rp_master_template_path, class: "btn-primary btn-sm btn-outline" %>
      <%= link_to "Cancel", rp_master_path, class: "cancel-link" %>
    </div>
  <% end %>
</div>
