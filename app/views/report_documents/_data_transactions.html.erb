<h3>RP Transactions</h3>
<% if records.any? %>
<table border="1" cellpadding="4" cellspacing="0" style="border-collapse:collapse; width:100%;">
  <tr><th>Counterparty</th><th>Nature</th><th>Sub-Nature</th><th>Type</th><th>Amount</th></tr>
  <% records.each do |t| %>
    <tr>
      <td><%= t.counterparty %></td>
      <td><%= t.nature %></td>
      <td><%= t.sub_nature %></td>
      <td><%= t.transaction_type %></td>
      <td><%= t.amount %></td>
    </tr>
  <% end %>
</table>
<% else %>
<p><em>No transactions found for selected entity/period.</em></p>
<% end %>
