<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "RP Transaction", rp_transactions_path %><span class="separator">›</span> Edit
<% end %>

<div class="page-header">
  <h2>Edit RP Transaction</h2>
</div>

<div class="card">
  <%= form_with model: @rp_transaction, url: rp_transaction_path(@rp_transaction), method: :patch do |f| %>
    <% if @rp_transaction.errors.any? %>
      <div class="form-errors mb-16">
        <% @rp_transaction.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="grid-2">
      <div class="form-group">
        <%= f.label :reporting_entity_id, "Reporting Entity" %>
        <%= f.select :reporting_entity_id, @reporting_entities.map { |e| [e.name, e.id] }, { prompt: "-- Select --" }, { class: "form-control", id: "form_reporting_entity" } %>
      </div>

      <div class="form-group">
        <%= f.label :reporting_unit_id, "Reporting Unit" %>
        <%= f.select :reporting_unit_id, ReportingUnit.where(reporting_entity_id: @rp_transaction.reporting_entity_id).map { |u| [u.name, u.id] }, { prompt: "-- Select --" }, { class: "form-control", id: "form_reporting_unit" } %>
      </div>

      <div class="form-group">
        <%= f.label :period_id, "Period" %>
        <%= f.select :period_id, @periods.map { |p| ["#{p.month} - #{p.financial_year}", p.id] }, { prompt: "-- Select --" }, { class: "form-control" } %>
      </div>

      <div class="form-group">
        <%= f.label :counterparty %>
        <%= f.select :counterparty, @counterparties.map { |name| [name, name] }, { prompt: "-- Select Counterparty --" }, { class: "form-control" } %>
      </div>

      <div class="form-group">
        <%= f.label :nature, "Nature of Transaction" %>
        <%= f.select :nature, @natures.map { |n| [n, n] }, { prompt: "-- Select --" }, { class: "form-control", id: "form_nature" } %>
      </div>

      <div class="form-group">
        <%= f.label :sub_nature, "Sub-Nature of Transaction" %>
        <%= f.select :sub_nature, Transaction.where(nature: @rp_transaction.nature).distinct.pluck(:sub_type).compact.map { |s| [s, s] }, { prompt: "-- Select --" }, { class: "form-control", id: "form_sub_nature" } %>
      </div>

      <div class="form-group">
        <%= f.label :transaction_type, "Type of Transaction" %>
        <%= f.select :transaction_type, Transaction.where(nature: @rp_transaction.nature, sub_type: @rp_transaction.sub_nature).distinct.pluck(:transaction_type).compact.map { |t| [t, t] }, { prompt: "-- Select --" }, { class: "form-control", id: "form_transaction_type" } %>
      </div>

      <div class="form-group">
        <%= f.label :amount %>
        <%= f.text_field :amount, placeholder: "Enter Amount", class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :main_code, "Main Code" %>
        <%= f.text_field :main_code, class: "form-control", id: "form_main_code", readonly: true %>
      </div>

      <div class="form-group">
        <%= f.label :sub_code, "Sub Code" %>
        <%= f.text_field :sub_code, class: "form-control", id: "form_sub_code", readonly: true %>
      </div>

      <div class="form-group">
        <%= f.label :ic_code, "IC Code" %>
        <%= f.text_field :ic_code, class: "form-control", id: "form_ic_code", readonly: true %>
      </div>
    </div>

    <div class="mt-16">
      <%= f.submit "Update Transaction", class: "btn-primary" %>
      <%= link_to "Cancel", rp_transactions_path, class: "btn-secondary ml-8" %>
    </div>
  <% end %>
</div>

<% content_for :page_script do %>
  <%= javascript_include_tag "rp_transactions_form" %>
<% end %>
