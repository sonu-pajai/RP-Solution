<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> RP Transaction
<% end %>

<div class="page-header">
  <h2>RP Transaction</h2>
  <div>
    <%= link_to "＋ Create Record", new_rp_transaction_path(reporting_entity_id: @selected_entity_id, reporting_unit_id: @selected_unit_id, period_id: @selected_period_id), class: "btn-primary btn-sm" %>
    <%= link_to "⬆ Bulk Upload", bulk_upload_rp_transactions_path, class: "btn-primary btn-sm btn-outline ml-8" %>
    <%= link_to "Export CSV", export_rp_transactions_path(reporting_entity_id: @selected_entity_id, reporting_unit_id: @selected_unit_id, period_id: @selected_period_id), class: "btn-primary btn-sm btn-outline ml-8" %>
  </div>
</div>

<div class="card mb-16">
  <div class="flex-row">
    <div class="form-group flex-1 mb-0">
      <label for="reporting_entity">Reporting Entity</label>
      <select id="reporting_entity" class="form-control">
        <option value="">-- All Reporting Entities --</option>
        <% @reporting_entities.each do |entity| %>
          <option value="<%= entity.id %>" <%= entity.id == @selected_entity_id ? "selected" : "" %>><%= entity.name %></option>
        <% end %>
      </select>
    </div>

    <div class="form-group flex-1 mb-0">
      <label for="reporting_unit">Reporting Unit</label>
      <select id="reporting_unit" class="form-control" <%= @selected_entity_id.blank? ? "disabled" : "" %>>
        <% if @selected_entity_id.blank? %>
          <option value="">-- Select Reporting Entity first --</option>
        <% else %>
          <option value="">-- All Reporting Units --</option>
          <% @reporting_units.each do |unit| %>
            <option value="<%= unit.id %>" <%= unit.id == @selected_unit_id ? "selected" : "" %>><%= unit.name %></option>
          <% end %>
        <% end %>
      </select>
    </div>

    <div class="form-group flex-1 mb-0">
      <label for="period">Period</label>
      <select id="period" class="form-control">
        <option value="">-- All Periods --</option>
        <% @periods.each do |period| %>
          <option value="<%= period.id %>" <%= period.id == @selected_period_id ? "selected" : "" %>><%= period.month %></option>
        <% end %>
      </select>
    </div>
  </div>
</div>

<div class="card">
  <div class="overflow-x">
    <table class="data-table">
      <thead>
        <tr>
          <th>Reporting Entity</th>
          <th>Reporting Unit</th>
          <th>Period</th>
          <th>Counterparty</th>
          <th>Type</th>
          <th>Nature</th>
          <th>Sub-Nature</th>
          <th>Main Code</th>
          <th>Sub Code</th>
          <th>Amount</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @rp_transactions.each do |txn| %>
          <tr class="clickable-row"
              data-entity-id="<%= txn.reporting_entity_id %>"
              data-unit-id="<%= txn.reporting_unit_id %>"
              data-period-id="<%= txn.period_id %>">
            <td><%= txn.reporting_entity.name %></td>
            <td><%= txn.reporting_unit.name %></td>
            <td><%= txn.period.month %></td>
            <td><%= txn.counterparty %></td>
            <td><%= txn.transaction_type %></td>
            <td><%= txn.nature %></td>
            <td><%= txn.sub_nature %></td>
            <td><%= txn.main_code %></td>
            <td><%= txn.sub_code %></td>
            <td class="amount"><%= number_to_currency(txn.amount, unit: "₹") %></td>
            <td class="rp-actions">
              <%= link_to "👁", rp_transaction_path(txn), title: "View", class: "rp-action-icon" %>
              <%= link_to "✏️", edit_rp_transaction_path(txn), title: "Edit", class: "rp-action-icon" %>
              <%= link_to "🗑", rp_transaction_path(txn), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, title: "Delete", class: "rp-action-icon" %>
            </td>
          </tr>
        <% end %>
        <% if @rp_transactions.empty? %>
          <tr><td colspan="11" class="empty-row text-center text-muted">No transactions found.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= render "shared/pagination", collection: @rp_transactions %>
<% content_for :page_script do %>
  <%= javascript_include_tag "rp_transactions_index" %>
<% end %>
