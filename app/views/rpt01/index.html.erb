<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> RPT-01
<% end %>

<div class="page-header">
  <h2>RPT-01 — RP Transactions Summary</h2>
</div>

<div style="overflow-x:auto;">
  <table class="data-table" style="min-width:max-content; font-size:13px;">
    <thead>
      <tr>
        <th style="white-space:nowrap;">Reporting Entity</th>
        <th style="white-space:nowrap;">Reporting Unit</th>
        <th style="white-space:nowrap;">Type of Transaction</th>
        <th style="white-space:nowrap;">Counter Reporting Entity</th>
        <th style="white-space:nowrap;">Sub-Type of Transaction</th>
        <% @periods.each do |p| %>
          <th style="white-space:nowrap; text-align:right;"><%= p.month %></th>
        <% end %>
        <th style="white-space:nowrap; text-align:right; background:#f0f9ff;">Current Qtr</th>
        <th style="white-space:nowrap; text-align:right; background:#f0fdf4;">Total</th>
      </tr>
    </thead>
    <tbody>
      <% if @rows.empty? %>
        <tr><td colspan="<%= 5 + @periods.size + 2 %>" class="empty-row">No transactions found.</td></tr>
      <% else %>
        <% @rows.each do |row| %>
          <tr>
            <td><%= row[:reporting_entity] %></td>
            <td><%= row[:reporting_unit] %></td>
            <td><%= row[:transaction_type] %></td>
            <td><%= row[:counterparty] %></td>
            <td><%= row[:sub_nature] %></td>
            <% @period_months.each do |month| %>
              <td style="text-align:right;">
                <% val = row[:amounts][month].to_f %>
                <%= val > 0 ? number_with_delimiter(val.round(2)) : "-" %>
              </td>
            <% end %>
            <td style="text-align:right; background:#f0f9ff; font-weight:600;">
              <%= number_with_delimiter(row[:current_quarter_total].round(2)) %>
            </td>
            <td style="text-align:right; background:#f0fdf4; font-weight:600;">
              <%= number_with_delimiter(row[:grand_total].round(2)) %>
            </td>
          </tr>
        <% end %>

        <%# Grand total row %>
        <tr style="font-weight:700; border-top:2px solid #cbd5e1; background:#f8fafc;">
          <td colspan="5">Total</td>
          <% @period_months.each do |month| %>
            <td style="text-align:right;">
              <%= number_with_delimiter(@rows.sum { |r| r[:amounts][month].to_f }.round(2)) %>
            </td>
          <% end %>
          <td style="text-align:right; background:#f0f9ff;">
            <%= number_with_delimiter(@rows.sum { |r| r[:current_quarter_total] }.round(2)) %>
          </td>
          <td style="text-align:right; background:#f0fdf4;">
            <%= number_with_delimiter(@rows.sum { |r| r[:grand_total] }.round(2)) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
