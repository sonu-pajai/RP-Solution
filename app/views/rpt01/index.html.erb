<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> RPT-01
<% end %>

<div class="page-header">
  <h2>RPT-01 — RP Transactions Summary</h2>
</div>

<div class="card mb-16">
  <div class="flex-row" style="align-items:flex-end; gap:16px;">
    <div class="form-group flex-1 mb-0">
      <label for="period_id">Period</label>
      <select id="period_id" class="form-control">
        <option value="">-- Current Quarter (Default) --</option>
        <% @all_periods.each do |p| %>
          <option value="<%= p.id %>" <%= @selected_period_id == p.id ? 'selected' : '' %>>
            <%= p.month %>
          </option>
        <% end %>
      </select>
    </div>
  </div>
</div>

<div style="overflow-x:auto;">
  <table class="data-table" style="min-width:max-content; font-size:13px;">
    <thead>
      <tr>
        <th style="white-space:nowrap;">Reporting Entity</th>
        <th style="white-space:nowrap;">Reporting Unit</th>
        <th style="white-space:nowrap;">Type of Transaction</th>
        <th style="white-space:nowrap;">Counter Reporting Entity</th>
        <th style="white-space:nowrap;">Sub-Type of Transaction</th>
        <% @quarter_cols.each do |q| %>
          <th style="white-space:nowrap; text-align:right;"><%= q[:label] %></th>
        <% end %>
        <th style="white-space:nowrap; text-align:right; background:#f0fdf4;">Total</th>
      </tr>
    </thead>
    <tbody>
      <% if @rows.empty? %>
        <tr><td colspan="<%= 5 + @quarter_cols.size + 1 %>" class="empty-row">No transactions found.</td></tr>
      <% else %>
        <% @rows_by_entity.each do |entity_name, entity_rows| %>
          <% entity_rows.each do |row| %>
            <tr>
              <td><%= row[:reporting_entity] %></td>
              <td><%= row[:reporting_unit] %></td>
              <td><%= row[:transaction_type] %></td>
              <td><%= row[:counterparty] %></td>
              <td><%= row[:sub_nature] %></td>
              <% @quarter_cols.each do |q| %>
                <td style="text-align:right;">
                  <% val = row[:amounts][q[:key]].to_f %>
                  <%= val > 0 ? number_with_delimiter(val.round(2)) : "-" %>
                </td>
              <% end %>
              <td style="text-align:right; background:#f0fdf4; font-weight:600;">
                <%= number_with_delimiter(row[:total].round(2)) %>
              </td>
            </tr>
          <% end %>

          <%# Entity subtotal row %>
          <tr style="font-weight:700; background:#eff6ff; border-top:1px solid #bfdbfe;">
            <td colspan="5" style="color:#1d4ed8;"><%= entity_name %> — Subtotal</td>
            <% @quarter_cols.each do |q| %>
              <td style="text-align:right; color:#1d4ed8;">
                <%= number_with_delimiter(entity_rows.sum { |r| r[:amounts][q[:key]].to_f }.round(2)) %>
              </td>
            <% end %>
            <td style="text-align:right; background:#dbeafe; color:#1d4ed8;">
              <%= number_with_delimiter(entity_rows.sum { |r| r[:total] }.round(2)) %>
            </td>
          </tr>
        <% end %>

        <%# Grand total %>
        <tr style="font-weight:700; border-top:2px solid #cbd5e1; background:#f8fafc;">
          <td colspan="5">Grand Total</td>
          <% @quarter_cols.each do |q| %>
            <td style="text-align:right;">
              <%= number_with_delimiter(@rows.sum { |r| r[:amounts][q[:key]].to_f }.round(2)) %>
            </td>
          <% end %>
          <td style="text-align:right; background:#f0fdf4;">
            <%= number_with_delimiter(@rows.sum { |r| r[:total] }.round(2)) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% content_for :page_script do %>
<script>
  document.getElementById('period_id').addEventListener('change', function() {
    var val = this.value;
    window.location.href = '/rpt01' + (val ? '?period_id=' + val : '');
  });
</script>
<% end %>
