<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "RP List", rp_list_path %><span class="separator">›</span> RP List Consolidation
<% end %>

<h2>RP List Consolidation</h2>

<!-- Selection Parameters -->
<div class="filter-bar mb-16">
  <div class="flex-row-end">
    <div class="form-group flex-1 mb-0">
      <%= label_tag :reporting_entity_id, "Reporting Entity" %>
      <%= select_tag :reporting_entity_id, options_from_collection_for_select(ReportingEntity.all, :id, :name, @reporting_entity_id.to_i), prompt: "Select Reporting Entity", id: "entity-select", class: "form-control" %>
    </div>

    <div class="form-group flex-1 mb-0">
      <%= label_tag :period_id, "Period" %>
      <%= select_tag :period_id, options_from_collection_for_select(Period.all, :id, :month, @period_id.to_i), prompt: "Select Period", id: "period-select", class: "form-control" %>
    </div>
  </div>
</div>

<% if @reporting_entity_id.present? && @period_id.present? %>
  <!-- Tabs -->
  <div class="tabs mb-16">
    <%= link_to rp_list_consolidation_path(reporting_entity_id: @reporting_entity_id, period_id: @period_id, tab: "to_submit"), class: "tab #{'tab-active' if @tab == 'to_submit'}" do %>
      To Be Submitted (<%= @to_submit_count %>)
    <% end %>
    <%= link_to rp_list_consolidation_path(reporting_entity_id: @reporting_entity_id, period_id: @period_id, tab: "submitted"), class: "tab #{'tab-active' if @tab == 'submitted'}" do %>
      Submitted (<%= @submitted_count %>)
    <% end %>
  </div>

  <!-- Search & Export -->
  <div class="filter-bar mb-16">
    <div class="flex-row-end">
      <div class="form-group flex-1 mb-0">
        <%= label_tag :search, "Search" %>
        <%= text_field_tag :search, params[:search], placeholder: "Type to search by code or name...", id: "search-filter", autocomplete: "off", class: "form-control" %>
      </div>
      <% if params[:search].present? %>
        <%= link_to "Clear", rp_list_consolidation_path(reporting_entity_id: @reporting_entity_id, period_id: @period_id, tab: @tab), class: "action-link" %>
      <% end %>
      <%= link_to "Export CSV", rp_list_consolidation_export_path(reporting_entity_id: @reporting_entity_id, period_id: @period_id, search: params[:search]), class: "btn-primary btn-sm btn-outline" %>
      <%= link_to "Bulk Upload", rp_list_consolidation_bulk_upload_path, class: "btn-primary btn-sm btn-outline" %>
    </div>
  </div>

  <% if @tab == "to_submit" %>
    <!-- To Be Submitted -->
    <%= form_with(url: rp_list_consolidation_submit_path, method: :post) do |f| %>
      <%= hidden_field_tag :reporting_entity_id, @reporting_entity_id %>
      <%= hidden_field_tag :period_id, @period_id %>

      <div class="page-header">
        <div>
          <label style="font-size:14px; cursor:pointer;">
            <input type="checkbox" id="select-all"> Select All
          </label>
        </div>
        <%= f.submit "Submit", class: "btn-primary btn-sm" %>
      </div>

      <div class="overflow-x">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width:40px;">
                <input type="checkbox" id="select-all-header">
              </th>
              <th>Unique Code</th>
              <th>Name</th>
              <th>PAN</th>
              <th>Category</th>
              <th>Related Party From</th>
              <th>Related Party Upto</th>
              <th>Any Other Input (Custom)</th>
            </tr>
          </thead>
          <tbody>
            <% @rp_masters.each do |rp| %>
              <tr>
                <td><%= check_box_tag "rp_master_ids[]", rp.id, false, class: "rp-checkbox" %></td>
                <td><%= rp.unique_code %></td>
                <td><%= rp.name %></td>
                <td><%= rp.pan %></td>
                <td><%= rp.category %></td>
                <td><%= date_field_tag "related_party_from[#{rp.id}]", nil, class: "form-control" %></td>
                <td><%= date_field_tag "related_party_upto[#{rp.id}]", nil, class: "form-control" %></td>
                <td><%= text_field_tag "custom_input[#{rp.id}]", nil, placeholder: "Enter value", class: "form-control" %></td>
              </tr>
            <% end %>
            <% if @rp_masters.empty? %>
              <tr><td colspan="8" class="empty-row text-center text-muted">No records to submit.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%= render "shared/pagination", collection: @rp_masters %>

  <% else %>
    <!-- Submitted -->
    <div class="overflow-x">
      <table class="data-table">
        <thead>
          <tr>
            <th>Unique Code</th>
            <th>Name</th>
            <th>PAN</th>
            <th>Category</th>
            <th>Related Party From</th>
            <th>Related Party Upto</th>
            <th>Custom Input</th>
            <th>Submitted At</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @rp_consolidations.each do |rc| %>
            <tr>
              <td><%= rc.rp_master.unique_code %></td>
              <td><%= rc.rp_master.name %></td>
              <td><%= rc.rp_master.pan %></td>
              <td><%= rc.rp_master.category %></td>
              <td><%= rc.related_party_from %></td>
              <td><%= rc.related_party_upto %></td>
              <td><%= rc.custom_input %></td>
              <td><%= rc.created_at.strftime("%d-%b-%Y") %></td>
              <td class="nowrap">
                <%= link_to "Edit", edit_rp_consolidation_path(rc), class: "action-link" %>
                <%= link_to "Delete", destroy_rp_consolidation_path(rc), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "action-link danger" %>
              </td>
            </tr>
          <% end %>
          <% if @rp_consolidations.empty? %>
            <tr><td colspan="9" class="empty-row text-center text-muted">No submitted records.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= render "shared/pagination", collection: @rp_consolidations %>
  <% end %>
<% end %>

<script>
  var entitySelect = document.getElementById('entity-select');
  var periodSelect = document.getElementById('period-select');
  var searchFilter = document.getElementById('search-filter');
  var debounceTimer;

  function loadRecords() {
    if (entitySelect.value && periodSelect.value) {
      window.location.href = '/rp_list_consolidation?reporting_entity_id=' + entitySelect.value + '&period_id=' + periodSelect.value;
    }
  }

  entitySelect.addEventListener('change', loadRecords);
  periodSelect.addEventListener('change', loadRecords);

  if (searchFilter) {
    searchFilter.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() {
        var params = [];
        params.push('reporting_entity_id=' + entitySelect.value);
        params.push('period_id=' + periodSelect.value);
        params.push('tab=<%= @tab %>');
        if (searchFilter.value) params.push('search=' + encodeURIComponent(searchFilter.value));
        window.location.href = '/rp_list_consolidation?' + params.join('&');
      }, 500);
    });
  }

  var selectAllHeader = document.getElementById('select-all-header');
  var selectAll = document.getElementById('select-all');
  var checkboxes = document.querySelectorAll('.rp-checkbox');

  function toggleAll(checked) {
    checkboxes.forEach(function(cb) { cb.checked = checked; });
    if (selectAllHeader) selectAllHeader.checked = checked;
    if (selectAll) selectAll.checked = checked;
  }

  if (selectAllHeader) selectAllHeader.addEventListener('change', function() { toggleAll(this.checked); });
  if (selectAll) selectAll.addEventListener('change', function() { toggleAll(this.checked); });
</script>
