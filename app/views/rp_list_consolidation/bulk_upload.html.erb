<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "RP List", rp_list_path %><span class="separator">›</span> <%= link_to "RP List Consolidation", rp_list_consolidation_path %><span class="separator">›</span> Bulk Upload
<% end %>

<div class="page-header">
  <h2>Bulk Upload - RP List Consolidation</h2>
  <%= link_to "← Back", rp_list_consolidation_path, class: "action-link" %>
</div>

<div class="card">
  <div class="info-box">
    <p class="info-box-title">📋 File Format</p>
    <p class="info-box-text">
      Upload a CSV file with these columns:<br>
      <code>Unique Code | Name | Related Party From | Related Party Upto | Any Other Input (Custom)</code>
    </p>
  </div>

  <div class="mb-24">
    <%= link_to rp_list_consolidation_template_path, class: "sample-download" do %>
      <span class="sample-download-icon">📥</span>
      <span><strong>Download Template</strong><br><span class="sample-download-subtitle">CSV template with correct headers</span></span>
    <% end %>
  </div>

  <%= form_with(url: rp_list_consolidation_bulk_upload_path, method: :post, multipart: true) do |f| %>
    <div class="grid-2 mb-16">
      <div class="form-group mb-0">
        <label>Reporting Entity</label>
        <%= select_tag :reporting_entity_id, options_from_collection_for_select(ReportingEntity.all, :id, :name), prompt: "Select Reporting Entity", class: "form-control" %>
      </div>

      <div class="form-group mb-0">
        <label>Period</label>
        <%= select_tag :period_id, options_from_collection_for_select(Period.all, :id, :month), prompt: "Select Period", class: "form-control" %>
      </div>
    </div>

    <div class="form-group">
      <label>Select File</label>
      <%= f.file_field :file, accept: ".csv", class: "form-control" %>
      <span class="form-hint">Accepted: .csv</span>
    </div>

    <div class="warning-box">
      <p>
        <strong>💡 Validations:</strong><br>
        • Reporting Entity and Period must be selected<br>
        • Unique Code must exist in RP Master<br>
        • Rows with invalid Unique Code will be skipped
      </p>
    </div>

    <div class="flex-row">
      <%= f.submit "⬆ Upload", class: "btn-primary btn-lg" %>
      <%= link_to "Cancel", rp_list_consolidation_path, class: "btn-secondary" %>
    </div>
  <% end %>
</div>
