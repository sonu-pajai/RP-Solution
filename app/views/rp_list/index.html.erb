<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "RP List", rp_list_path %> <span class="separator">›</span> RP List
<% end %>

<h2>RP List</h2>

<div class="module-grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
  <%= link_to rp_master_path, class: "module-card" do %>
    <div class="module-card-header blue">RP Master</div>
    <div class="module-card-body">RP Master</div>
  <% end %>

  <%= link_to rp_list_consolidation_path, class: "module-card" do %>
    <div class="module-card-header white-bordered">RP List Consolidation</div>
    <div class="module-card-body">Input</div>
  <% end %>

  <%= link_to rp_consolidation_output_path, class: "module-card" do %>
    <div class="module-card-header white-bordered">RP List Consolidation</div>
    <div class="module-card-body">Output</div>
  <% end %>
</div>
