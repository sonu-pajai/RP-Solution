<% content_for :breadcrumb do %>
  <%= link_to "Dashboard", root_path %><span class="separator">›</span> <%= link_to "Masters", reporting_entities_path %><span class="separator">›</span> Relationships
<% end %>

<div class="page-header">
  <h2>Relationships</h2>
  <div class="flex-row">
    <% if can? :create, Relationship %>
      <%= link_to "＋ Add New", new_relationship_path, class: "btn-primary btn-sm" %>
      <%= link_to "Bulk Upload", bulk_upload_relationships_path, class: "btn-primary btn-sm btn-outline" %>
    <% end %>
  </div>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th>Relationship</th>
      <th>Category</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @relationships.each do |rel| %>
      <tr>
        <td><%= rel.name %></td>
        <td><%= rel.category %></td>
        <td class="rp-actions">
          <% if can? :update, rel %>
            <%= link_to "✏️", edit_relationship_path(rel), title: "Edit", class: "rp-action-icon" %>
          <% end %>
          <% if can? :destroy, rel %>
            <%= link_to "🗑", relationship_path(rel), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, title: "Delete", class: "rp-action-icon" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

