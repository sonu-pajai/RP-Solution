<h2>New Relationship</h2>

<%= form_with(model: @relationship, class: "form-container") do |f| %>
  <% if @relationship.errors.any? %>
    <div class="form-errors">
      <% @relationship.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "Relationship" %>
    <%= f.text_field :name, placeholder: "Enter relationship" %>
  </div>

  <div class="form-group">
    <%= f.label :category %>
    <%= f.select :category, Relationship::CATEGORIES, { prompt: "Select category" } %>
  </div>

  <div class="form-actions">
    <%= f.submit "Create", class: "btn-primary btn-submit" %>
    <%= link_to "Cancel", relationships_path, class: "cancel-link" %>
  </div>
<% end %>
